SMTH_HOST=bbs.mysmth.net
SMTH_PORT=23
SMTH_BOARD=stock

# 格式: username:password,username2:password2,username3:password3
SMTH_ACCOUNTS=user1:pass1,user2:pass2,user3:pass3

# 逗号分隔。禁用账号即使出现在 SMTH_ACCOUNTS 中也不会登录。
SMTH_DISABLED_ACCOUNTS=

# 同一账号两次连接尝试之间的最小间隔秒数。
SMTH_MIN_RECONNECT_INTERVAL=30

# 读取到数据后，连续空闲多少秒即认为本次响应结束。
SMTH_IDLE_TIMEOUT=0.06

# 同一账号两次读帖之间的最小间隔秒数，以及额外随机抖动秒数。
SMTH_PER_ACCOUNT_INTERVAL=3
SMTH_REQUEST_JITTER=1

# 遇到审核提示后，账号读帖间隔会按倍数放大，连续成功后逐步恢复。
SMTH_AUDIT_SLOWDOWN_MULTIPLIER=2
SMTH_MAX_PER_ACCOUNT_INTERVAL=15
SMTH_RECOVERY_SUCCESSES=500

# 0 表示 partial 解析失败不触发主动重连。
SMTH_RECONNECT_AFTER_SHORT_PARTIAL=0

# 单个账号遇到审核提示后的暂停秒数；暂停后从触发审核的帖子继续。
SMTH_AUDIT_BLOCK_COOLDOWN=300
